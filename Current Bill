units = int(input())

# calculate base amount
if units <= 199:
    amount = units * 1.20
elif units <= 399:
    amount = units * 1.50
elif units <= 599:
    amount = units * 1.80
else:
    amount = units * 2.00

# apply surcharge
if amount > 400:
    amount += amount * 0.15
else:
    amount += 100

print(f"{amount:.2f}")
